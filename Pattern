import java.util.*;

public class Pattern1 {
    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);
        // rows vala kam --> outer loops
        // columns vala kam --> inner loops
        for(int i=1; i<=4; i++){
            for(int j=1; j<=5; j++){
                System.out.print("*");

            }
            System.out.println();

        }
        
    }
    
}
